{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.25/MicrosoftTeams.schema.json",
  "version": "1.0.0",
  "manifestVersion": "1.25",
  "id": "08bc5dd7-f534-41e4-933e-a2e5c4324051",
  "name": {
    "short": "jeembot"
  },
  "developer": {
    "name": "jeembot",
    "websiteUrl": "https://nexlr-2404-8000-1096-4153-a99f-ae7-dad8-cbb7.a.free.pinggy.link",
    "privacyUrl": "https://nexlr-2404-8000-1096-4153-a99f-ae7-dad8-cbb7.a.free.pinggy.link/privacy",
    "termsOfUseUrl": "https://nexlr-2404-8000-1096-4153-a99f-ae7-dad8-cbb7.a.free.pinggy.link/tos"
  },
  "description": {
    "short": "jeembot",
    "full": "Teams bot that integrates with ClickUp for task management. It allows users to create, update, and manage tasks directly from Microsoft Teams conversations."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#ffffff",
  "bots": [
    {
      "botId": "e09e26fc-9231-4610-b130-f4494c4fb069",
      "scopes": ["personal", "team", "groupChat"],
      "isNotificationOnly": false,
      "supportsCalling": false,
      "supportsVideo": false,
      "supportsFiles": false,
      "commandLists": [
        {
          "scopes": ["personal", "team", "groupChat"],
          "commands": [
            {
              "title": "Create Task",
              "description": "Create a new task in ClickUp. Usage: /to <team> <task description>"
            },
            {
              "title": "Help",
              "description": "Show available commands and how to use Jeembot"
            },
            {
              "title": "Hello",
              "description": "Get a greeting and quick intro to Jeembot"
            }
          ]
        }
      ]
    }
  ],
  "composeExtensions": [
    {
      "botId": "e09e26fc-9231-4610-b130-f4494c4fb069",
      "commands": [],
      "messageHandlers": [
        {
          "type": "link",
          "value": {
            "domains": ["*.pinggy.link"]
          }
        }
      ]
    }
  ],
  "validDomains": ["*.pinggy.link"],
  "defaultGroupCapability": {
    "team": "bot",
    "groupchat": "bot",
    "meetings": "bot"
  },
  "supportsChannelFeatures": "tier1"
}
